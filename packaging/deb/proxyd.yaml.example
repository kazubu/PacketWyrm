# PacketWyrm Web GUI / RPC gateway (packetwyrm-proxyd) configuration.
# Read with:  packetwyrm-proxyd --config /etc/packetwyrm/proxyd.yaml
# Any CLI flag overrides the matching key here. One `key: value` per line;
# `#` comments and blank lines are ignored.

# Bind address for the HTTPS listener (ADDR:PORT, or just PORT).
# Default is loopback-only: safe for a fresh install and for SSH-tunnel access
# (ssh -L 8443:127.0.0.1:8443 host). To expose it on the network set 0.0.0.0
# AND either configure system.secret in the daemon's env config or set
# insecure_no_auth below (a public bind fail-closes otherwise).
listen: "127.0.0.1:8443"

# Daemon control socket to relay onto (must match the daemon's control_socket).
socket: "/run/packetwyrm/packetwyrmd.sock"

# TLS: leave both blank for an auto-generated self-signed certificate, or point
# at a real PEM cert/key pair. Must be set together.
tls_cert: ""
tls_key: ""

# Serve plain HTTP instead of HTTPS. Localhost / SSH-tunnel only -- the access
# secret would cross the network in the clear otherwise.
no_tls: false

# Allow a non-loopback bind even when the daemon requires no secret. Only
# meaningful with a 0.0.0.0 listen; leaves the control plane unauthenticated.
insecure_no_auth: false

# Extra Host header values accepted on POST /api/rpc (anti DNS-rebinding).
# localhost, 127.0.0.1, [::1] and the listen address are always accepted;
# add the hostname/IP clients use to reach a network-exposed gateway.
# Comma-separated, e.g. "pwhost1.lab,172.21.100.104".
allowed_hosts: ""
