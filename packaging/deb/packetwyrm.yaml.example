# ============================================================================
#  EDIT ME  --  PacketWyrm environment config  (/etc/packetwyrm/packetwyrm.yaml)
# ============================================================================
#  This is a SAMPLE seeded by the packetwyrm package. It will NOT work as-is:
#  you MUST set your card's real PCI address and adjust the logical interfaces
#  for your setup before starting the daemon.
#
#    - system.mode / default_speed: match your hardware
#    - cards[].pci: the PCI BDF of YOUR card (see `pktwyrm cards` to discover)
#    - logical_interfaces: the ports/VLANs/MACs your test uses
#
#  NO secret is set here. To require a control-socket secret (recommended when
#  exposing the Web GUI), uncomment `system.secret` below; clients that can read
#  this file inherit access (read permission == ACL). Keep this file 0640.
#
#  This file is a dpkg conffile: your edits survive package upgrades.
#  Load a test config (flows/forwards) at runtime with `pktwyrm load <test>.yaml`
#  or start the daemon with `-t <test>.yaml`.
# ============================================================================
system:
  name: "pw-env"
  mode: "multi-card"
  default_speed: "10g"
#  control_socket: "/run/packetwyrm/packetwyrmd.sock"
#  secret: "change-me"     # uncomment to require it on the control socket
cards:
  - id: 0
    name: "card0"
    pci: "0000:07:00.0"    # <-- EDIT: set to your card's real PCI BDF
    ports:
      - { local_port: 0, global_port: 0, name: "p0" }
      - { local_port: 1, global_port: 1, name: "p1" }
logical_interfaces:
  - id: 1000
    global_port: 0
    vlan: 100
    mac: "02:a5:02:00:00:64"
    mtu: 9000
    punt: { arp: false, ipv6_nd: false, lldp: false, icmp: false, bgp: false, ospf: false }
